# Telegram bot token dari @BotFather
TELEGRAM_BOT_TOKEN=123456:ABCDEF

# Chat ID/channel/group tujuan. Bisa dapat dari @userinfobot, atau masukkan @channelusername untuk channel publik.
TELEGRAM_CHAT_ID=your_chat_id_or_@channelusername

# Polling interval detik
POLL_INTERVAL_SECONDS=60

# Jangan spam historical pools saat pertama run: true = simpan existing lalu alert hanya pool baru setelah itu
SKIP_EXISTING_ON_FIRST_RUN=true

# Filter pair harus mengandung TON native
REQUIRE_NATIVE_TON=true

# Optional: token TonAPI kalau punya, supaya rate limit lebih lega
TONAPI_KEY=

# Endpoint default
DEDUST_POOLS_URL=https://api.dedust.io/v2/pools
TONAPI_BASE_URL=https://tonapi.io/v2

# x1000.finance/launches memakai public DeDust coins API ini. Dipakai untuk mengambil
# memecoin_extra_details (author, curve, holders, market_cap, dll) sebagai
# enrichment data alert (deployer wallet, bonding curve, stats, social links).
X1000_ENABLED=true
X1000_API_URL=https://mainnet.api.dedust.io/v4/api/coins

# Base URL terminal x1000 yang dipakai untuk tombol "Open x1000 Chart".
X1000_BASE_URL=https://x1000.finance

# Optional pattern route token. Kosongkan kalau belum ada route token-specific
# yang confirmed valid; bot akan fallback ke X1000_BASE_URL.
# Placeholder yang disupport: {asset}, {address}, {jetton_addr}, {jetton_address}.
# Contoh: /coins/{asset}  atau  /tokens/{jetton_address}
X1000_TOKEN_ROUTE_PATTERN=

# Optional. Hanya dipakai kalau di kemudian hari endpoint x1000/DeDust coins API
# memerlukan cookie. Header Cookie hanya dilampirkan ke request x1000.
X1000_COOKIE=

# STON.fi (DEX kedua terbesar di TON) sebagai sumber pool tambahan.
# Pool address tidak collide dengan DeDust, jadi state seen aman dipakai bareng.
STONFI_ENABLED=true
STONFI_POOLS_URL=https://api.ston.fi/v1/pools

# Format alert
PROGRESS_BAR_LENGTH=10
DESCRIPTION_MAX_CHARS=300
MAX_SOCIAL_LINKS=5

# Spam guard: minimum native-TON reserves (in TON, not nano) for a pool to
# qualify as a launch alert. 0 = disabled (kirim semua), 10 = wajib >=10 TON.
MIN_TON_RESERVES=0

# Graduation alert: kirim alert terpisah ketika bonded curve memepad
# mencapai persentase ini. Default 99%. Set 101 untuk disable.
GRADUATION_THRESHOLD_PCT=99

# Tandai deployer dengan ⚠️ kalau wallet yang sama deploy >= jumlah token
# ini di list x1000 (24h window). 0 = disable.
DEV_CLUSTER_WARN_THRESHOLD=3

# Render tombol Telegram inline_keyboard (Chart / DEX Pool / Tonviewer)
# alih-alih HTML <a> link di body message. true (default) lebih clickable.
INLINE_BUTTONS=true

# In-memory cache TTLs (seconds). 0 effectively disables caching for that key.
# - TonAPI jetton metadata berubah jarang, default 1 jam aman.
# - Balance dev wallet berubah lebih cepat tapi reuse antar pool dalam 1 tick masih hemat.
# - x1000 list di-share di antara semua pool dalam 1 tick.
TONAPI_CACHE_TTL_SECONDS=3600
BALANCE_CACHE_TTL_SECONDS=60
X1000_CACHE_TTL_SECONDS=30

# HTTP retry policy. Otomatis retry pada 429 + 5xx (TonAPI rate limit, Telegram 429).
# Backoff factor: delay = backoff * (2 ** retry_count). Default 1.0 → 1s, 2s, 4s.
# Set HTTP_RETRIES=0 untuk disable.
HTTP_RETRIES=3
HTTP_BACKOFF_FACTOR=1.0

STATE_FILE=./state/seen_pools.json

# Prometheus metrics + /healthz HTTP server. 0 disables the server entirely.
# Counters are still incremented in-process so tests can assert on them.
METRICS_PORT=0
