# Telegram bot token dari @BotFather
TELEGRAM_BOT_TOKEN=123456:ABCDEF

# Chat ID/channel/group tujuan. Bisa dapat dari @userinfobot, atau masukkan @channelusername untuk channel publik.
TELEGRAM_CHAT_ID=your_chat_id_or_@channelusername

# Polling interval detik
POLL_INTERVAL_SECONDS=60

# Jangan spam historical pools saat pertama run: true = simpan existing lalu alert hanya pool baru setelah itu
SKIP_EXISTING_ON_FIRST_RUN=true

# Filter pair harus mengandung TON native
REQUIRE_NATIVE_TON=true

# Optional: token TonAPI kalau punya, supaya rate limit lebih lega
TONAPI_KEY=

# Endpoint default
DEDUST_POOLS_URL=https://api.dedust.io/v2/pools
TONAPI_BASE_URL=https://tonapi.io/v2

# x1000.finance/launches memakai public DeDust coins API ini. Dipakai untuk mengambil
# memecoin_extra_details (author, curve, holders, market_cap, dll) sebagai
# enrichment data alert (deployer wallet, bonding curve, stats, social links).
X1000_ENABLED=true
X1000_API_URL=https://mainnet.api.dedust.io/v4/api/coins

# Base URL terminal x1000 yang dipakai untuk tombol "Open x1000 Chart".
X1000_BASE_URL=https://x1000.finance

# Optional pattern route token. Kosongkan kalau belum ada route token-specific
# yang confirmed valid; bot akan fallback ke X1000_BASE_URL.
# Placeholder yang disupport: {asset}, {address}, {jetton_addr}, {jetton_address}.
# Contoh: /coins/{asset}  atau  /tokens/{jetton_address}
X1000_TOKEN_ROUTE_PATTERN=

# Optional. Hanya dipakai kalau di kemudian hari endpoint x1000/DeDust coins API
# memerlukan cookie. Header Cookie hanya dilampirkan ke request x1000.
X1000_COOKIE=

# Format alert
PROGRESS_BAR_LENGTH=10
DESCRIPTION_MAX_CHARS=300
MAX_SOCIAL_LINKS=5

STATE_FILE=./state/seen_pools.json
